# ============================================================================
# AI Code Assistant — Environment Variables
# ============================================================================
# !! 安全警告: 此文件是模板。请复制为 .env 并填入真实值。!!
# !! .env 包含密钥，已在 .gitignore 中排除，切勿提交到版本控制。!!
#
# 获取 QWEN_API_KEY: https://dashscope.console.aliyun.com/apiKey

# Qwen DashScope API (Alibaba Cloud)
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Redis
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
WORKERS=1
SESSION_TTL_SECONDS=86400

# API 认证 (留空则不启用认证)
API_AUTH_TOKEN=

# CORS 跨域 (逗号分隔, 默认 * 允许所有来源)
CORS_ORIGINS=*

# 速率限制
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_SECONDS=60

# 可观测性 (可选)
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=ai-code-assistant
# SENTRY_DSN=
